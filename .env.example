# =============================================================================
# ForkReplay — environment variable catalog (self-host)
# Copy to .env.local and fill in values. NEVER commit .env.local or any secret.
# Full reference: docs/deployment/configuration.md
#
# ForkReplay is open-source and self-hostable. Backends are pluggable; you only
# need the vars for the components your deployment uses. ClickHouse is REQUIRED
# in every mode (no Postgres substitute). "Pluggable Postgres" is control-plane
# only.
# =============================================================================

# -----------------------------------------------------------------------------
# Control-plane Postgres — pluggable via DB_MODE
#   compose  = bundled Postgres container (quickstart default)
#   custom   = bring-your-own Postgres (RDS / Azure DB / self-managed)
#   supabase = managed or self-hosted Supabase Postgres
# -----------------------------------------------------------------------------
DB_MODE=compose
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=forkreplay
POSTGRES_USER=
POSTGRES_PASSWORD=
# Full DSN (overrides the discrete POSTGRES_* vars if set)
DATABASE_URL=

# -----------------------------------------------------------------------------
# Auth — GoTrue (Supabase Auth OSS) in ALL modes; app validates GoTrue JWTs
# -----------------------------------------------------------------------------
GOTRUE_SITE_URL=
GOTRUE_API_EXTERNAL_URL=
GOTRUE_JWT_SECRET=
GOTRUE_JWT_AUD=authenticated

# -----------------------------------------------------------------------------
# ClickHouse (REQUIRED — span/frame analytics; bundled in compose)
# -----------------------------------------------------------------------------
CLICKHOUSE_URL=
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=forkreplay

# -----------------------------------------------------------------------------
# Object storage — S3-compatible abstraction
#   MinIO (compose) / AWS S3 (Terraform AWS) / Azure Blob (Terraform Azure)
# -----------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_FRAMES=forkreplay-frames
S3_BUCKET_BLOBS=forkreplay-frames-blobs

# -----------------------------------------------------------------------------
# Ingest queue — NATS primary; Redis Streams is the lighter alternative
# -----------------------------------------------------------------------------
QUEUE_BACKEND=nats
NATS_URL=
NATS_CREDS=

# -----------------------------------------------------------------------------
# Live streaming — Redis pub/sub (backs FastAPI SSE + system banners)
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# Durable orchestration — Temporal (self-hosted)
# -----------------------------------------------------------------------------
TEMPORAL_HOST=
TEMPORAL_NAMESPACE=default
# Only if Temporal mTLS is enabled:
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=

# -----------------------------------------------------------------------------
# LLM routing (pluggable): openrouter | openai | anthropic | ollama
# -----------------------------------------------------------------------------
LLM_PROVIDER=openrouter
LLM_API_BASE=
LLM_API_KEY=

# -----------------------------------------------------------------------------
# BYOK key custody (optional KEK for envelope-encrypting workspace LLM keys)
#   KEK_PROVIDER: none | age | libsodium
# -----------------------------------------------------------------------------
KEK_PROVIDER=none
# Comma-separated age recipient public keys (multi-recipient supported):
KEK_AGE_RECIPIENTS=
# Path to the age identity file used to decrypt (operator-held; never commit):
KEK_AGE_IDENTITY_FILE=

# -----------------------------------------------------------------------------
# Email (pluggable; required for GoTrue confirmations): smtp | resend | console
# -----------------------------------------------------------------------------
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# -----------------------------------------------------------------------------
# Observability (optional) — any OTLP-compatible sink (self-hosted collector,
# Grafana/Prometheus, etc.). Leave unset to disable.
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# -----------------------------------------------------------------------------
# Web (Next.js standalone container)
# -----------------------------------------------------------------------------
WEB_PUBLIC_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_GOTRUE_URL=

# -----------------------------------------------------------------------------
# DEPRECATED — only needed to deploy the legacy Cloudflare workers
# (workers/otlp-gateway, workers/sse-relay), which are slated for removal.
# Supplied at deploy time; never hard-code account IDs in wrangler.toml.
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
